# Rename this file to .env and fill in your values.

# API key from https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# Base URL for the OpenWeatherMap API (optional – defaults to the value below)
WEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# Port the HTTP server will listen on (optional – defaults to 8080)
SERVER_PORT=8080
