# Rename this file to .env and fill in your values.

# Base URL for the Open-Meteo weather API (optional – defaults to the value below)
WEATHER_BASE_URL=https://api.open-meteo.com/v1

# Base URL for the Open-Meteo geocoding API (optional – defaults to the value below)
GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com/v1

# Port the HTTP server will listen on (optional – defaults to 8080)
SERVER_PORT=8080
